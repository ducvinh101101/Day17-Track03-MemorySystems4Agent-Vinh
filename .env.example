# Antco AI Gateway (OpenAI-compatible / LiteLLM proxy)
LLM_PROVIDER=custom
LLM_MODEL=gemini-3.1-flash-lite
CUSTOM_BASE_URL=https://ai-gateway.antco.ai/v1
CUSTOM_API_KEY=replace_with_your_key
LLM_TEMPERATURE=0

# 0 = deterministic local benchmark; 1 = call the real gateway.
BENCHMARK_LIVE=0

# Compact-memory configuration
COMPACT_THRESHOLD_TOKENS=1000
COMPACT_KEEP_MESSAGES=6
